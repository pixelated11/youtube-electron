{
  "name": "BetterYoutube",
  "version": "1.2.0",
  "main": "main.js",
  "description": "A Better Youtube desktop client built with electron.",
  "author": {
    "name": "pixelated11",
    "email": "itspixelatd@proton.me"
  },
  "scripts": {
    "start": "electron .",
    "build:linux": "electron-builder --linux",
    "build:windows": "electron-builder --win",
    "build:all": "electron-builder --linux --win"
  },
  "dependencies": {
    "@ghostery/adblocker-electron": "^2.0.0",
    "node-fetch": "^3.0.0"
  },
  "devDependencies": {
    "electron": "^41.0.0",
    "electron-builder": "^25.0.0",
    "@malept/flatpak-bundler": "^0.4.0"
  },
  "build": {
    "appId": "com.pixelated.betteryoutube",
    "productName": "BetterYoutube",
    "electronDownload": {
    	"mirror": "https://github.com/castlabs/electron-releases/releases/download/"
    
    },
    "files": [
      "main.js",
      "index.html",
      "preload.js",
      "scripts/",
      "extensions/"
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Network",
      "icon": "assets/icon_linux.png"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "assets/icon_windows.png"
    }
  }
}
