{
  "name": "BetterYoutube",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:linux": "electron-builder --linux",
    "build:windows": "electron-builder --win",
    "build:all": "electron-builder --linux --win"
  },
  "dependencies": {
    "@ghostery/adblocker-electron": "^2.0.0"
  },
  "devDependencies": {
    "electron": "^41.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.pixelated.betteryoutube",
    "productName": "BetterYoutube",
    "files": [
      "main.js",
      "index.html",
      "preload.js",
      "scripts/",
      "extensions/"
    ],
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Network"
    },
    "win": {
      "target": ["nsis", "portable"]
    }
  }
}

